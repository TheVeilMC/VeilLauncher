{
  "name": "VeilLauncher",
  "version": "0.0.1",
  "description": "The Veil Launcher - Electron Application",
  "main": "dist/main/core/index.js",
  "author": {
    "name": "OGMatrix",
    "email": "matrix@ogmatrix.net",
    "url": "https://ogmatrix.net"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p main/tsconfig.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer && npm run build:preload && && npm run build:shared npm run build:app",
    "build:dev": "npm run build:main && npm run build:renderer && npm run build:preload && npm run build:shared",
    "build:main": "tsc --noCheck -p main/tsconfig.json",
    "build:shared": "tsc --noCheck -p shared/tsconfig.json",
    "build:preload": "tsc --noCheck -p preload/tsconfig.json",
    "build:renderer": "vite build",
    "build:app": "electron-builder --config electron-builder.json --publish=never",
    "start": "electron . --trace-warnings",
    "dist": "vite build && electron-builder --config electron-builder.json --publish=never",
    "pack": "electron-builder --dir",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings 0",
    "test": "vue-tsc --noEmit",
    "test-jest": "jest --passWithNoTests",
    "postinstall": "electron-builder install-app-deps",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@the-veil/shared": "file:./shared",
    "@types/three": "^0.178.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.5",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "eslint-plugin-vue": "^10.3.0",
    "fs-extra": "^11.3.0",
    "skinview3d": "^3.4.1",
    "three": "^0.178.0",
    "ws": "^8.16.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/crypto-js": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9.31.0",
    "eslint-plugin-electron": "^7.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^30.0.5",
    "lucide-vue-next": "^0.307.0",
    "pinia": "^2.1.7",
    "postcss": "^8.4.32",
    "prettier": "^3.6.2",
    "rollup-plugin-obfuscator": "^1.1.0",
    "tailwindcss": "^3.4.0",
    "terser": "^5.43.1",
    "typescript": "^5.3.3",
    "vite": "^7.0.6",
    "vue": "^3.4.5",
    "vue-router": "^4.2.5",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.4"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "renderer/**/*.{js,jsx,ts,tsx}",
      "main/**/*.{js,jsx,ts,tsx}",
      "preload/**/*.{js,jsx,ts,tsx}",
      "!**/dist/**",
      "!**/build/**",
      "!**/node_modules/**",
      "!**/coverage/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  }
}
