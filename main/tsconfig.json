{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/main",
    "rootDir": ".",
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["./**/*"],
  "exclude": ["../node_modules", "../dist"]
}
